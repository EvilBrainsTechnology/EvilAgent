##############################################################################
# EvilAgent – environment configuration.
# Copy to .env and adjust:   cp .env.example .env
# The .env file is in .gitignore and MUST NOT be committed.
#
# No API keys here: every tool authenticates interactively on first start
# and stores its credentials in a persistent volume. If you need a key in
# the environment, add it yourself – but every agent in the container can
# then read it.
##############################################################################

# --- Container ---------------------------------------------------------------
CONTAINER_NAME=evilagent

# --- Resource limits ---------------------------------------------------------
CPUS=4
MEM_LIMIT=6g

# --- Ports -------------------------------------------------------------------
AGENTSMON_PORT=8765

# --- Network hardening (optional) --------------------------------------------
# Suggest an egress proxy to tools that honor these variables. This is not
# enforced: agents still have direct outbound access. See README.
# HTTP_PROXY=http://squid:3128
# HTTPS_PROXY=http://squid:3128
# NO_PROXY=localhost,127.0.0.1
