##############################################################################
# EvilAgent – environment configuration.
# Copy to .env and adjust:   cp .env.example .env
# The .env file is in .gitignore and MUST NOT be committed.
#
# There are deliberately no API keys here: every tool authenticates
# interactively on first start and stores its own credentials in a persistent
# volume, so you set auth up once per tool (see README). If a tool of yours
# needs a key in the environment, add it here yourself – but note that every
# agent in the container can then read it.
##############################################################################

# --- Container ---------------------------------------------------------------
# Change this (together with COMPOSE_PROJECT_NAME) to run a second stack
# alongside the first one with its own volumes.
CONTAINER_NAME=evilagent

# --- Resource limits ---------------------------------------------------------
CPUS=4
MEM_LIMIT=6g

# --- Tools -------------------------------------------------------------------
# Choose which tools get installed. Applies at image build time, so changing a
# value requires `docker compose build` (or `make update`) to take effect.
INSTALL_CODEX=true
INSTALL_CLAUDE_CODE=true
INSTALL_AGENT2TELEGRAM=true
INSTALL_HERMES=true
INSTALL_OPENCLAW=true
INSTALL_AGENTSMONITOR=true
INSTALL_ANTIGRAVITY=true
INSTALL_WHISPER=true

# Keeping agents running 24/7 is not configured here: the container runs cron,
# so `agentsmon setup` inside the container registers your agents and keeps them
# alive across restarts the standard way. See README.

# --- Network hardening (optional) --------------------------------------------
# Route agent traffic through an egress proxy with a domain allowlist. Without
# it, agents have unrestricted outbound access. See README.
# HTTP_PROXY=http://squid:3128
# HTTPS_PROXY=http://squid:3128
# NO_PROXY=localhost,127.0.0.1
