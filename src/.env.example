##############################################################################
# EvilAgent – environment configuration.
# Copy to .env and fill in values:   cp .env.example .env
# The .env file is in .gitignore and MUST NOT be committed.
#
# Most tools authenticate interactively on first start (see README), so these
# keys are OPTIONAL – only fill in the ones you want to pass directly via the
# environment (e.g. to run via API instead of a subscription).
##############################################################################

# --- Container identity ------------------------------------------------------
AGENT_UID=1000
AGENT_GID=1000

# --- Resource limits ---------------------------------------------------------
CPUS=4
MEM_LIMIT=6g

# --- Tools -------------------------------------------------------------------
# Choose which tools get installed (true/false). Applies at image build time
# and when refreshing tools via `make tools`. Changing a value requires
# `docker compose build` (or `make update`) to take effect in the image.

# Codex (OpenAI) – meta-agent, manages other agents
# Subscription: log in interactively via `codex` (device flow). API mode: key here.
INSTALL_CODEX=true
OPENAI_API_KEY=

# Claude Code (Anthropic) – development / agent
# Subscription: `claude` (login). API mode: key here.
INSTALL_CLAUDE_CODE=true
ANTHROPIC_API_KEY=

# Agent2Telegram – agent ↔ Telegram bridge
INSTALL_AGENT2TELEGRAM=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Hermes Agent (Nous Research) – agent + gateway
# Key for the local gateway (generated during setup: openssl rand -hex 24)
INSTALL_HERMES=true
HERMES_API_SERVER_KEY=

# OpenClaw – full-stack agent solution
INSTALL_OPENCLAW=true

# AgentsMonitor – monitoring + automatic recovery
INSTALL_AGENTSMONITOR=true

# Google Antigravity – agent (API-only on servers)
# On a server, runs via a Google Cloud project / API key, not a subscription.
INSTALL_ANTIGRAVITY=true
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=

# Whisper (OpenAI / faster-whisper) – voice control (Voice2Text)
# Also install the heavier openai-whisper (torch, ~2 GB)? Otherwise only
# faster-whisper is used.
# For best results consider ElevenLabs Scribe via the API (also supports Text2Voice).
INSTALL_WHISPER=true
INSTALL_OPENAI_WHISPER=false
ELEVENLABS_API_KEY=
