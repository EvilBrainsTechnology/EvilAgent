# LF line endings are mandatory for files used inside the Linux container.
# CRLF would break the script shebang (bad interpreter: /usr/bin/env^M).
*.sh            text eol=lf
Dockerfile      text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
Makefile        text eol=lf
.env.example    text eol=lf
