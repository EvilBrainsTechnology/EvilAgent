##############################################################################
# EvilAgent – konfigurace prostředí.
# Zkopírujte na .env a doplňte hodnoty:   cp .env.example .env
# Soubor .env je v .gitignore a NESMÍ se commitovat.
#
# Většina nástrojů se přihlašuje interaktivně po prvním startu (viz README),
# takže tyto klíče jsou VOLITELNÉ – vyplňte jen ty, které chcete předat
# rovnou přes prostředí (např. pro běh přes API místo předplatného).
##############################################################################

# --- Prostředky / identita (volitelné) --------------------------------------
AGENT_UID=1000
AGENT_GID=1000
CPUS=4
MEM_LIMIT=6g
# Nainstalovat i těžký openai-whisper (torch, ~2 GB)? Jinak jede faster-whisper.
INSTALL_OPENAI_WHISPER=false

# --- OpenAI (Codex) ---------------------------------------------------------
# Předplatné: přihlášení přes `codex` (device flow). API režim: klíč zde.
OPENAI_API_KEY=

# --- Anthropic (Claude Code) ------------------------------------------------
# Předplatné: `claude` (login). API režim: klíč zde.
ANTHROPIC_API_KEY=

# --- Telegram (Agent2Telegram) ----------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Hermes Agent -----------------------------------------------------------
# Klíč pro lokální gateway (vygeneruje se při konfiguraci: openssl rand -hex 24)
HERMES_API_SERVER_KEY=

# --- ElevenLabs (Scribe – hlas Voice2Text / Text2Voice) ---------------------
ELEVENLABS_API_KEY=

# --- Google (Antigravity / Gemini) ------------------------------------------
# Na serveru běží přes Google Cloud projekt / API klíč, ne přes předplatné.
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
