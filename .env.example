##############################################################################
# EvilAgent – environment configuration.
# Copy to .env and fill in values:   cp .env.example .env
# The .env file is in .gitignore and MUST NOT be committed.
#
# Most tools authenticate interactively on first start (see README), so these
# keys are OPTIONAL – only fill in the ones you want to pass directly via the
# environment (e.g. to run via API instead of a subscription).
##############################################################################

# --- Resources / identity (optional) ----------------------------------------
AGENT_UID=1000
AGENT_GID=1000
CPUS=4
MEM_LIMIT=6g
# Install the heavier openai-whisper (torch, ~2 GB)? Otherwise uses faster-whisper.
INSTALL_OPENAI_WHISPER=false

# --- OpenAI (Codex) ----------------------------------------------------------
# Subscription: log in interactively via `codex` (device flow). API mode: key here.
OPENAI_API_KEY=

# --- Anthropic (Claude Code) -------------------------------------------------
# Subscription: `claude` (login). API mode: key here.
ANTHROPIC_API_KEY=

# --- Telegram (Agent2Telegram) -----------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Hermes Agent ------------------------------------------------------------
# Key for the local gateway (generated during setup: openssl rand -hex 24)
HERMES_API_SERVER_KEY=

# --- ElevenLabs (Scribe – Voice2Text / Text2Voice) ---------------------------
ELEVENLABS_API_KEY=

# --- Google (Antigravity / Gemini) -------------------------------------------
# On a server, runs via a Google Cloud project / API key, not a subscription.
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
